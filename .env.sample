# Public base URL of the deployed site — used for canonical URLs,
# OpenGraph/Twitter metadata, sitemap entries and JSON-LD. A trailing slash is
# stripped, so either form works. Leave unset locally to fall back to the
# production domain (https://www.socialdownloader.space).
NEXT_PUBLIC_SITE_URL=

# Self-hosted cobalt API instance (media extractor/tunnel), used as a FALLBACK
# when the public community instance fails/rate-limits. Helps keep TikTok
# working under load on datacenter hosts (Vercel). See deploy/cobalt/ for a
# free Render deploy. Must include the trailing slash.
COBALT_API_URL=

# Optional: only if your cobalt instance has API-key auth enabled
# (API_AUTH_REQUIRED=1). Sent as `Authorization: Api-Key <key>`.
COBALT_API_KEY=

# Optional Instagram session cookie — the `sessionid` value from a logged-in
# instagram.com session. Only needed for LOGIN-GATED posts (ones Instagram
# refuses to serve to logged-out users); public reels/photos work without it.
# When set, the GraphQL extractor sends it so those posts can be resolved.
#
# How to get it: log into instagram.com (use a BURNER account — Instagram may
# flag accounts for automated access from datacenter/Vercel IPs), open DevTools
# → Application → Cookies → https://www.instagram.com, copy the `sessionid`
# value (the raw value, %3A escapes are fine). Paste it below (locally) or set
# it as a Vercel env var. It's long-lived (~1y) but can be invalidated earlier
# if the account logs out, changes password, or gets flagged — re-grab it when
# login-gated downloads start failing.
IG_SESSIONID=
